{
  "title": "Postly - Orchestration Overview",
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Duration (p95)",
      "type": "graph",
      "targets": [{ "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))" }],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Campaigns Processed (by status)",
      "type": "graph",
      "targets": [{ "expr": "sum(rate(postly_campaigns_processed_total[5m])) by (status)" }],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "id": 3,
      "title": "Agent Execution Duration",
      "type": "graph",
      "targets": [{ "expr": "histogram_quantile(0.95, rate(postly_agent_duration_seconds_bucket[5m])) by (agent)" }],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "id": 4,
      "title": "Node.js Process Memory",
      "type": "graph",
      "targets": [{ "expr": "process_resident_memory_bytes" }],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
