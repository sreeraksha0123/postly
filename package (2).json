{
  "name": "postly",
  "version": "1.0.0",
  "private": true,
  "description": "Multi-agent AI content orchestration platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "npm run build --workspace=apps/frontend --if-present",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:workers": "npm run dev --workspace=apps/workers",
    "dev:frontend": "npm run dev --workspace=apps/frontend",
    "migrate": "npm run migrate --workspace=apps/api",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "lint": "eslint . --ext .ts,.tsx",
    "docker:up": "docker compose -f docker/docker-compose.yml up --build",
    "docker:down": "docker compose -f docker/docker-compose.yml down -v"
  },
  "dependencies": {
    "minimist": "^1.2.8"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.7",
    "eslint": "^8.57.0",
    "@typescript-eslint/parser": "^7.7.0",
    "@typescript-eslint/eslint-plugin": "^7.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
