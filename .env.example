# Application Configuration
PORT=3000 
NODE_ENV=production # development, production, or test

# Database Configuration
# NOTE: DATABASE_URL is auto-provided by Railway PostgreSQL add-on
DATABASE_URL=postgresql://postgres:password@localhost:5432/postly

# Redis Configuration
# NOTE: REDIS_URL is auto-provided by Railway Redis add-on
REDIS_URL=redis://localhost:6379

# Authentication Configuration
JWT_ACCESS_SECRET= 
JWT_REFRESH_SECRET= 
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Security Configuration
ENCRYPTION_KEY= # 32-byte hex key for AES-256

# AI Provider Configuration
OPENAI_API_KEY=
GROQ_API_KEY=        # Internal fallback for Anthropic (Claude)
ANTHROPIC_API_KEY=   # Required for real Anthropic integration

# Telegram Integration Configuration
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL= 
WEBHOOK_SECRET= 
