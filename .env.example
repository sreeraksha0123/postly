# ==================== APP ====================
NODE_ENV=development
API_PORT=4000
FRONTEND_PORT=3000
LOG_LEVEL=info

# ==================== DATABASE ====================
DATABASE_URL=postgresql://postly:postly@localhost:5432/postly
POSTGRES_USER=postly
POSTGRES_PASSWORD=postly
POSTGRES_DB=postly

# ==================== REDIS / BULLMQ ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
QUEUE_CONCURRENCY=10
QUEUE_MAX_RETRIES=5
QUEUE_BACKOFF_MS=2000

# ==================== AI MODELS ====================
OPENAI_API_KEY=sk-xxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
GOOGLE_AI_API_KEY=xxxxxxxx
DEFAULT_MODEL_PROVIDER=anthropic

# ==================== VECTOR STORE ====================
# vectorstore driver: "pgvector" (default, no extra infra) or "pinecone"
VECTOR_STORE_DRIVER=pgvector
PINECONE_API_KEY=
PINECONE_INDEX=postly-rag
PINECONE_ENVIRONMENT=

# ==================== WEB / NEWS SEARCH (for Research Agent) ====================
SEARCH_API_KEY=
NEWS_API_KEY=

# ==================== PLATFORM INTEGRATIONS ====================
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
THREADS_ACCESS_TOKEN=

# ==================== SECURITY ====================
JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRES_IN=7d
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
ENCRYPTION_KEY=change-me-32-byte-key-for-aes-256

# ==================== OBSERVABILITY ====================
SENTRY_DSN=
PROMETHEUS_METRICS_PORT=9100
